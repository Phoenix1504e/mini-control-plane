cat <<EOF > .gitignore
# Binaries
bin/
tools/bin/

# Temporary directories
/tmp/
*.etcd/

# Python/Go/Build noise
__pycache__/
.venv/
*.log
*.so
*.test

# Experiment Data (unless specifically added)
experiments/*/run-*
results/*.txt
!results/results_run_2.txt
!results/results_run_3.txt

# OS Files
.DS_Store
EOF
